generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Editor
  KoreaTeam
  Admin
}

enum TaskStatus {
  Assigned
  Editing
  OnHold
  NeedToBeReviewed
  Review
  Revise
  ReadyToUpload
  Completed
}

enum VideoStatus {
  Pending
  Reviewed
  Approved
  Rejected
}

enum NotificationType {
  task_assigned
  task_status
  task_progress
  task_deleted
  task_reassigned
  task_on_hold
  task_started
  revision
  video_uploaded
  video_reviewed
  comment
  asset_uploaded
  call_invited
  user_created
  user_deleted
  clock_in
  clock_out
  deadline_warning
  weekly_report
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(Editor)
  locale       String   @default("id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  timeLogs          TimeLog[]
  assignedTasks     Task[]              @relation("AssignedTasks")
  createdTasks      Task[]              @relation("CreatedTasks")
  progressUpdates   ProgressUpdate[]
  videoSubmissions  VideoSubmission[]
  comments          Comment[]
  uploadedAssets    Asset[]
  createdRooms      CallRoom[]          @relation("RoomCreator")
  roomParticipants  CallParticipant[]
  roomInvites       CallRoomInvite[]
  sentInvites       CallRoomInvite[]    @relation("RoomInviter")
  statusLogs        TaskStatusLog[]
  notifications     Notification[]
  weeklyReports     WeeklyReport[]
  createdEvents     CalendarEvent[]

  @@map("users")
}

model TimeLog {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  clockIn          DateTime  @map("clock_in")
  clockOut         DateTime? @map("clock_out")
  durationMinutes  Int?      @map("duration_minutes")
  breakStartedAt   DateTime? @map("break_started_at")
  breakMinutesTotal Int      @default(0) @map("break_minutes_total")
  date             DateTime  @db.Date
  editedBy         String?   @map("edited_by")
  adjustmentNote   String?   @map("adjustment_note")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("time_logs")
}

model Task {
  id                String      @id @default(cuid())
  title             String
  description       String?
  briefUrl          String?     @map("brief_url")
  assignedTo        String      @map("assigned_to")
  assignedBy        String      @map("assigned_by")
  status            TaskStatus  @default(Assigned)
  deadline          DateTime?
  progressPercent   Int         @default(0) @map("progress_percent")
  revisionNote      String?     @map("revision_note")
  revisionAttachment String?    @map("revision_attachment")
  youtubeUrl        String?     @map("youtube_url")
  createdAt         DateTime    @default(now()) @map("created_at")

  assignee         User              @relation("AssignedTasks", fields: [assignedTo], references: [id])
  assigner         User              @relation("CreatedTasks", fields: [assignedBy], references: [id])
  progressUpdates  ProgressUpdate[]
  videoSubmissions VideoSubmission[]
  comments         Comment[]
  assets           Asset[]
  statusLogs       TaskStatusLog[]

  @@index([assignedTo, status])
  @@index([deadline])
  @@map("tasks")
}

model TaskStatusLog {
  id         String     @id @default(cuid())
  taskId     String     @map("task_id")
  userId     String     @map("user_id")
  fromStatus TaskStatus @map("from_status")
  toStatus   TaskStatus @map("to_status")
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_status_logs")
}

model ProgressUpdate {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  fileUrl   String?  @map("file_url")
  percent   Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("progress_updates")
}

model VideoSubmission {
  id          String       @id @default(cuid())
  taskId      String       @map("task_id")
  userId      String       @map("user_id")
  fileUrl     String       @map("file_url")
  fileSize    BigInt?      @map("file_size")
  version     Int          @default(1)
  status      VideoStatus  @default(Pending)
  submittedAt DateTime     @default(now()) @map("submitted_at")

  task     Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@index([taskId, version])
  @@map("video_submissions")
}

model Comment {
  id                 String           @id @default(cuid())
  taskId             String           @map("task_id")
  videoSubmissionId  String?          @map("video_submission_id")
  userId             String           @map("user_id")
  content            String
  timestampSeconds   Int?             @map("timestamp_seconds")
  parentId           String?          @map("parent_id")
  createdAt          DateTime         @default(now()) @map("created_at")

  task            Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  videoSubmission VideoSubmission? @relation(fields: [videoSubmissionId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  parent          Comment?         @relation("CommentThread", fields: [parentId], references: [id])
  replies         Comment[]        @relation("CommentThread")

  @@index([taskId])
  @@map("comments")
}

model Asset {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  uploadedBy String   @map("uploaded_by")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type")
  fileSize   BigInt?  @map("file_size")
  label      String?
  createdAt  DateTime @default(now()) @map("created_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@map("assets")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String           @default("")
  body        String           @default("")
  titleKey    String?          @map("title_key")
  titleParams Json?            @map("title_params")
  bodyKey     String?          @map("body_key")
  bodyParams  Json?            @map("body_params")
  taskId      String?          @map("task_id")
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model WeeklyReport {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  weekStart     DateTime @map("week_start") @db.Date
  totalMinutes  Int      @default(0) @map("total_minutes")
  tasksCompleted Int     @default(0) @map("tasks_completed")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
  @@map("weekly_reports")
}

enum CallRoomType {
  office
  breakout
  private
  meeting
}

model CallRoom {
  id        String       @id @default(cuid())
  name      String
  type      CallRoomType
  roomName  String       @map("room_name")
  createdBy String       @map("created_by")
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")

  creator      User              @relation("RoomCreator", fields: [createdBy], references: [id])
  participants CallParticipant[]
  invites      CallRoomInvite[]

  @@map("call_rooms")
}

model CallParticipant {
  id        String    @id @default(cuid())
  roomId    String    @map("room_id")
  userId    String    @map("user_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  room CallRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("call_participants")
}

model CallRoomInvite {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  invitedBy String   @map("invited_by")
  createdAt DateTime @default(now()) @map("created_at")

  room    CallRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviter User     @relation("RoomInviter", fields: [invitedBy], references: [id])

  @@unique([roomId, userId])
  @@map("call_room_invites")
}

enum EventType {
  holiday
  event
  meeting
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType
  date        DateTime  @db.Date
  endDate     DateTime? @db.Date    @map("end_date")
  isAllDay    Boolean   @default(true) @map("is_all_day")
  color       String?
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@map("calendar_events")
}
